{
  "name": "sgw-sample | Secure Dev Environment",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": ["Anthropic.claude-code", "esbenp.prettier-vscode"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.visualBell": "both",
        "accessibility.signals.terminalBell": {
          "sound": "on",
          "announcement": "auto"
        },
        "accessibility.signals.sounds.volume": 100,
        "audioCues.terminalBell": "on",
        "audioCues.volume": 100
      }
    }
  },
  "remoteUser": "vscode",
  "postStartCommand": "sudo /usr/local/bin/sekimore-agent-setup.sh && sh /workspace/.devcontainer/scripts/post-create.sh",
  "waitFor": "postStartCommand"
}
